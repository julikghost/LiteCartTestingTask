{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@pages": ["pages/index.ts"],
      "@pages/*": ["pages/*"],
      "@components": ["components/index.ts"],
      "@components/*": ["components/*"],
      "@helpers/*": ["helpers/*"],
      "@data/*": ["data/*"],
      "@fixtures/*": ["fixtures/*"],
      "@api/*": ["api/*"],
      "@app/*": ["app/*"],
      "@auth/*": ["auth/*"]
    }
  },
  "include": [
    "api/**/*.ts",
    "app/**/*.ts",
    "auth/**/*.ts",
    "components/**/*.ts",
    "data/**/*.ts",
    "fixtures/**/*.ts",
    "helpers/**/*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts"
  ]
}
